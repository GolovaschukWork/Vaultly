# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vaultly?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/vaultly?schema=public"

# Supabase Auth — same Project URL as in apps/web/.env
SUPABASE_URL="https://your-project.supabase.co"

# Optional fallback for legacy HS256 JWTs
SUPABASE_JWT_SECRET="your-jwt-secret"

# Server
PORT=3001

