# Supabase PostgreSQL (Project Settings → Database → Connection string)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# Supabase Auth — same Project URL as in apps/web/.env
SUPABASE_URL="https://your-project.supabase.co"

# Service role key for signed PDF preview URLs (Project Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Storage bucket name
SUPABASE_STORAGE_BUCKET="vaultly-files"

# Optional fallback for legacy HS256 JWTs
SUPABASE_JWT_SECRET="your-jwt-secret"

# Server
PORT=3001
